{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user (Teacher or Learner) in the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "userName": { "type": "string" },
        "fullName": { "type": "string" },
        "rank": { "type": "string", "enum": ["teacher", "learner"] },
        "className": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "photoURL": { "type": "string" },
        "isActive": { "type": "boolean" },
        "scores": {
          "type": "object",
          "description": "Map of testName to score"
        }
      },
      "required": ["uid", "email", "rank"]
    },
    "Test": {
      "title": "Test",
      "description": "A classroom examination template.",
      "type": "object",
      "properties": {
        "testId": { "type": "string" },
        "testName": { "type": "string" },
        "className": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "markingScheme": {
          "type": "object",
          "description": "Map of questionId to mark value (usually index or score)"
        }
      }
    },
    "Question": {
      "title": "Question",
      "description": "A single question within a test.",
      "type": "object",
      "properties": {
        "questionId": { "type": "string" },
        "questionText": { "type": "string" },
        "imageUrl": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswerIndex": { "type": "number" },
        "answeredUsers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "TestAttempt": {
      "title": "TestAttempt",
      "description": "A learner's progress or result for a specific test.",
      "type": "object",
      "properties": {
        "attemptId": { "type": "string" },
        "uid": { "type": "string" },
        "testId": { "type": "string" },
        "testName": { "type": "string" },
        "className": { "type": "string" },
        "startedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "isSubmitted": { "type": "boolean" },
        "score": { "type": "number" },
        "percentage": { "type": "number" },
        "answers": {
          "type": "object",
          "description": "Map of questionId to {selectedAnswer, isCorrect, updatedAt}"
        }
      }
    }
  },
  "firestore": {
    "users/{uid}": {
      "schema": "User",
      "description": "User profiles and metadata."
    },
    "tests/{testId}": {
      "schema": "Test",
      "description": "Test definitions."
    },
    "tests/{testId}/questions/{questionId}": {
      "schema": "Question",
      "description": "Questions linked to a test."
    },
    "testAttempts/{attemptId}": {
      "schema": "TestAttempt",
      "description": "Individual test results and progress."
    }
  }
}
