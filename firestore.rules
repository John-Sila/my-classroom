rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return isSignedIn() && getUserData().rank == 'teacher';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string
        && data.userName is string && data.userName.size() <= 100
        && data.rank in ['teacher', 'learner']
        && (data.rank == 'teacher' || data.className is string)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidTest(data) {
      return data.testName is string && data.testName.size() <= 200
        && data.className is string
        && data.durationMinutes is number && data.durationMinutes > 0
        && data.createdBy == request.auth.uid
        && data.isActive is bool;
    }

    function isValidQuestion(data) {
      return data.questionText is string && data.questionText.size() <= 2000
        && data.options is list && data.options.size() >= 2
        && data.correctAnswerIndex is number;
    }

    function isValidAttempt(data) {
      return data.uid == request.auth.uid
        && data.testId is string
        && data.isSubmitted is bool;
    }

    // --- Rules ---

    match /users/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isTeacher());
      allow create: if isSignedIn() && isOwner(uid) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(uid) 
        && incoming().rank == existing().rank // Rank is immutable
        && incoming().uid == existing().uid
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['lastLogin', 'updatedAt', 'photoURL', 'userName', 'fullName', 'scores'])
        );
    }

    match /tests/{testId} {
      allow read: if isSignedIn() && (isTeacher() || getUserData().className == resource.data.className);
      allow create: if isTeacher() && isValidTest(incoming());
      allow update: if isTeacher() && incoming().createdBy == existing().createdBy;
      allow delete: if isTeacher() && existing().createdBy == request.auth.uid;

      match /questions/{questionId} {
        allow read: if isSignedIn() && (isTeacher() || getUserData().className == get(/databases/$(database)/documents/tests/$(testId)).data.className);
        allow write: if isTeacher();
      }
    }

    match /testAttempts/{attemptId} {
      allow read: if isSignedIn() && (isOwner(existing().uid) || isTeacher());
      allow create: if isSignedIn() && isValidAttempt(incoming());
      allow update: if isSignedIn() && isOwner(existing().uid)
        && existing().isSubmitted == false // Cannot update submitted test
        && (
          // Action: Answer question or Submit
          incoming().diff(existing()).affectedKeys().hasAny(['answers', 'isSubmitted', 'submittedAt', 'score', 'percentage', 'updatedAt'])
        )
        && incoming().uid == existing().uid
        && incoming().testId == existing().testId
        && incoming().updatedAt == request.time;
    }
  }
}
