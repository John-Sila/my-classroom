rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'jsila3000@gmail.com'; }
    function getUserData() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; 
    }
    function isTeacher() { 
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().rank == 'teacher')
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'rank', 'userName', 'fullName', 'className', 'isActive']) &&
             data.uid == request.auth.uid &&
             data.rank in ['teacher', 'learner'] &&
             data.userName is string && data.userName.size() <= 50 &&
             data.fullName is string && data.fullName.size() <= 100;
    }

    function isValidTest(data) {
      return data.keys().hasAll(['testName', 'className', 'durationMinutes', 'createdBy', 'isActive']) &&
             data.testName is string && data.testName.size() <= 200 &&
             data.durationMinutes is number && data.durationMinutes > 0 &&
             data.createdBy == request.auth.uid;
    }

    function isValidAttempt(data) {
      return data.keys().hasAll(['uid', 'testId', 'testName', 'className', 'isSubmitted', 'score', 'percentage', 'answers']) &&
             data.uid == request.auth.uid &&
             data.testId is string &&
             data.score is number &&
             data.percentage is number &&
             data.answers is map;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isTeacher();
      allow create: if isSignedIn() && (request.auth.uid == userId || isTeacher());
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['lastLogin', 'photoURL', 'userName', 'fullName'])) ||
        isTeacher()
      );
    }

    match /tests/{testId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isTeacher() && isValidTest(incoming());
      allow update: if isTeacher() && isValidTest(incoming());
      allow delete: if isTeacher();

      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow write: if isTeacher();
      }
    }

    match /testAttempts/{attemptId} {
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || isTeacher());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isTeacher());
      allow create: if isSignedIn() && isValidAttempt(incoming());
      allow update: if isSignedIn() && (
        (resource.data.uid == request.auth.uid && !existing().isSubmitted && (
          // Action: Answer Question
          incoming().diff(existing()).affectedKeys().hasOnly(['answers', 'updatedAt']) ||
          // Action: Submit Test
          incoming().diff(existing()).affectedKeys().hasOnly(['isSubmitted', 'score', 'percentage', 'submittedAt', 'answers', 'updatedAt'])
        )) ||
        isTeacher()
      );
    }
  }
}
